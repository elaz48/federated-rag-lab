# Required: OpenAI-compatible API key
OPENAI_API_KEY=sk-...

# Optional: override the default OpenAI API base (e.g. Azure, local proxy, OpenRouter)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Chat model used for generation, routing, SQL, and eval judging
LLM_MODEL=gpt-4o-mini

# Embedding model used for document indexing and retrieval
EMBEDDING_MODEL=text-embedding-3-small
